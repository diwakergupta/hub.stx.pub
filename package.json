{
  "name": "stx-pub",
  "version": "0.1.0",
  "description": "Stacks miner telemetry explorer visualizing block commits and miner power",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.tsx",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.tsx",
    "test": "bun test"
  },
  "dependencies": {
    "@chakra-ui/charts": "^3.35.0",
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@viz-js/viz": "^3.27.0",
    "c32check": "^2.0.0",
    "croner": "^10.0.1",
    "panzoom": "^9.4.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/bun": "^1.3.14"
  }
}
